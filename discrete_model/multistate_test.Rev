morpho <- readDiscreteCharacterData("discrete_model/discrete_character_data.nex")
taxa <- readTaxonData("discrete_model/taxa_data.tsv")

for (i in 1:taxa.size()) {
    ages[i] = taxa[i].getMaxAge()
}
max_age = max(ages)

nchar <- morpho.nchar()
num_states <- morpho.getNumStatesVector()

for (i in 1:nchar) {
    file <- "discrete_model/matrices/q_matrix_" + i + ".csv"
    contents <- readDelimitedDataFile(file, header = TRUE, separator=",", rownames=FALSE)

    for (j in 1:contents.size()) {
        rates[i][j] <- contents[j][1]
    }

    n = rates[i].size()
    k = round((1 + sqrt(1 + 4 * n)) / 2)

    q[i] <- fnFreeK(rates[i], rescaled=true)
}

moves = VectorMoves()



#Speciation and extinction rates
lambda <- ln(100)

psi ~ dnExponential(10000) 
moves.append( mvScale(psi, lambda=0.1,  weight=1) )

speciation_rate ~ dnExponential(lambda)
moves.append( mvScale(speciation_rate, lambda = 0.1, weight=1) )

extinction_rate ~ dnExponential(lambda)
moves.append( mvScale(extinction_rate, lambda = 0.1, weight=1) )

#Probability of sampling extant taxa (rho)
rho <- 1.0

#Origin time
origin_time ~ dnUnif(max_age, 3100)

moves.append( mvSlide(origin_time, delta=0.1,  weight=5.0) )

#Define FBD distribution
fbd_tree ~ dnFBDP(origin=origin_time, lambda=speciation_rate, mu=extinction_rate, psi=psi, rho=rho, taxa=taxa)

moves.append( mvFNPR(fbd_tree, weight=15.0) )
moves.append( mvCollapseExpandFossilBranch(fbd_tree, origin_time, weight=6.0) )

moves.append( mvNodeTimeSlideUniform(fbd_tree, weight=40.0) )
moves.append( mvRootTimeSlideUniform(fbd_tree, origin_time, weight=5.0) )

#accounting for age uncertainty
fossils = fbd_tree.getFossils()

for(i in 1:fossils.size())
{
    t[i] := tmrca(fbd_tree, clade(fossils[i]))
    a_i = fossils[i].getMinAge()
    b_i = fossils[i].getMaxAge()
    F[i] ~ dnUniform(t[i] - b_i, t[i] - a_i)
    F[i].clamp(0)
}

moves.append( mvFossilTimeSlideUniform(fbd_tree, origin_time, weight=15.0) )

# Set up Gamma-distributed rate variation.
alpha_morpho ~ dnUniform( 0.0, 1E6 )
rates_morpho := fnDiscretizeGamma( alpha_morpho, alpha_morpho, 4 )

# Moves on the parameters to the Gamma distribution.
moves.append( mvScale(alpha_morpho,lambda=1, weight=2.0) )

for (i in 1:nchar) {
    morpho_part[i] <- morpho
    morpho_part[i].excludeAll()
    morpho_part[i].includeCharacter(i)

    m_morph[i] ~ dnPhyloCTMC( tree=fbd_tree,
                               Q=q[i],
                               nSites=1,
                               siteRates=rates_morpho,
                               type="Standard")

    m_morph[i].clamp(morpho_part[i])  
}


mymodel = model(fbd_tree)

monitors = VectorMonitors()
monitors.append( mnModel(filename="discrete_model/output/mk_gamma.log", printgen=10) )
monitors.append( mnFile(filename="discrete_model/output/mk_gamma.trees", printgen=10, fbd_tree) )
monitors.append( mnScreen(printgen=100) )


mymcmc = mcmc(mymodel, monitors, moves, nruns=2, combine="mixed")
mymcmc.burnin(1000, tuningInterval=100)
mymcmc.run(generations=10000)

trace = readTreeTrace("discrete_model/output/mk_gamma.trees")
mccTree(trace, file= "discrete_model/output/discrete_test_mcc.tree")

q()